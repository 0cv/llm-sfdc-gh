# ─────────────────────────────────────────────
# Cloud Run environment variables
# (these are set on the Cloud Run service)
# ─────────────────────────────────────────────

# Gmail OAuth2
# Run `npm run auth-gmail` once to get the refresh token
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# Claude OAuth token — generated by: claude setup-token
# Used by Cloud Run for triage (via @anthropic-ai/sdk authToken) and by the
# claude CLI in GitHub Actions runner sessions (via CLAUDE_CODE_OAUTH_TOKEN)
CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token

# GitHub — token must have contents+PR write access on all repos in routing.json
GITHUB_TOKEN=ghp_...

# Admin endpoint secret — used by Cloud Scheduler to call /admin/renew-watch
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your-admin-secret

# Gmail Pub/Sub topic — created by setup-gcp.sh
# Format: projects/<gcp-project-id>/topics/sf-errors
GMAIL_PUBSUB_TOPIC=projects/salesforceerrors-491311/topics/sf-errors

# ─────────────────────────────────────────────
# GitHub Actions secrets
# (set these in each SF repo's Settings → Secrets → Actions)
# ─────────────────────────────────────────────

# CLAUDE_CODE_OAUTH_TOKEN — same token as above, set as a GitHub Actions secret
# SF_AUTH_URL=force://PlatformCLI::<token>@yourorg.sandbox.my.salesforce.com

# ─────────────────────────────────────────────
# Local dev only (not used in Cloud Run)
# ─────────────────────────────────────────────

PORT=3000
DEDUP_TTL_HOURS=24
